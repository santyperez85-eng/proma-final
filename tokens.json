{
  "$metadata": {
    "name": "pro.ma Color System v1.0 — Umbral",
    "version": "1.1.0",
    "date": "2026-03-20",
    "description": "Sistema de identidad visual pro.ma Studio. Wordmark: proma (sin punto). La m en Playfair Display Italic es el umbral tipográfico. El punto vive en el sistema de unidades (pro.pack, pro.brand, pro.web)."
  },

  "color": {
    "primitive": {
      "navy-900": { "value": "#1C2340", "description": "Base modo oscuro" },
      "navy-700": { "value": "#2E3A5C", "description": "Surface modo oscuro" },
      "terra-500": { "value": "#D4521A", "description": "Acento universal — punto del sistema de unidades" },
      "terra-700": { "value": "#B5420F", "description": "Acento oscuro — hover states" },
      "cream-50":  { "value": "#FAF8F4", "description": "Base modo claro" },
      "cream-100": { "value": "#F2EDE4", "description": "Texto sobre oscuro" },
      "cream-200": { "value": "#EAE6DE", "description": "Surface modo claro / borde" },
      "text-dark":  { "value": "#2C2420", "description": "Texto principal sobre claro" }
    },
    "semantic": {
      "dark": {
        "bg":           { "value": "{color.primitive.navy-900}" },
        "surface":      { "value": "{color.primitive.navy-700}" },
        "accent":       { "value": "{color.primitive.terra-500}" },
        "accent-hover": { "value": "{color.primitive.terra-700}" },
        "text-primary": { "value": "{color.primitive.cream-100}" },
        "text-accent":  { "value": "{color.primitive.terra-500}" },
        "border":       { "value": "{color.primitive.navy-700}" }
      },
      "light": {
        "bg":           { "value": "{color.primitive.cream-50}" },
        "surface":      { "value": "{color.primitive.cream-200}" },
        "accent":       { "value": "{color.primitive.terra-500}" },
        "accent-hover": { "value": "{color.primitive.terra-700}" },
        "text-primary": { "value": "{color.primitive.text-dark}" },
        "text-accent":  { "value": "{color.primitive.terra-500}" },
        "border":       { "value": "{color.primitive.cream-200}" }
      }
    }
  },

  "typography": {
    "fontFamily": {
      "wordmark":        { "value": "'Grantha Sangam MN', serif",       "description": "Wordmark — caracteres p, r, o, a. No usar fuera del wordmark." },
      "wordmark-accent": { "value": "'Playfair Display', serif",         "description": "Wordmark — solo la m en italic. El umbral tipográfico. No usar fuera del wordmark." },
      "primary":         { "value": "'Plus Jakarta Sans', sans-serif",   "description": "Títulos, cuerpo, UI, navegación" },
      "mono":            { "value": "'IBM Plex Mono', monospace",         "description": "Trazabilidad técnica, versiones, refs, sufijos de unidades (pro.pack, pro.brand...)" }
    },
    "fontWeight": {
      "regular":  { "value": "400" },
      "medium":   { "value": "500" },
      "semibold": { "value": "600" },
      "bold":     { "value": "700" }
    },
    "scale": {
      "t1-hero":     { "size": "36px", "weight": "700", "family": "primary", "tracking": "-0.04em", "lineHeight": "1.15" },
      "t2-title":    { "size": "28px", "weight": "600", "family": "primary", "tracking": "-0.02em", "lineHeight": "1.2"  },
      "t3-subtitle": { "size": "22px", "weight": "600", "family": "primary", "tracking": "0",       "lineHeight": "1.3"  },
      "t4-label":    { "size": "18px", "weight": "500", "family": "primary", "tracking": "0",       "lineHeight": "1.4"  },
      "body":        { "size": "14px", "weight": "400", "family": "primary", "tracking": "0",       "lineHeight": "1.6"  },
      "small":       { "size": "12px", "weight": "400", "family": "primary", "tracking": "0",       "lineHeight": "1.5"  },
      "label-ui":    { "size": "11px", "weight": "500", "family": "primary", "tracking": "0.08em",  "lineHeight": "1"    },
      "mono-lg":     { "size": "15px", "weight": "400", "family": "mono",    "tracking": "0.06em",  "lineHeight": "1.4"  },
      "mono-md":     { "size": "12px", "weight": "400", "family": "mono",    "tracking": "0.04em",  "lineHeight": "1.4"  },
      "mono-sm":     { "size": "11px", "weight": "400", "family": "mono",    "tracking": "0.02em",  "lineHeight": "1.4"  }
    }
  },

  "wordmark": {
    "name": "proma",
    "note": "Sin punto. La m en Playfair Display Italic es el umbral tipográfico.",
    "structure": {
      "pro": { "font": "Grantha Sangam MN", "style": "Regular", "color-dark": "#F2EDE4", "color-light": "#2C2420" },
      "m":   { "font": "Playfair Display",  "style": "Italic",  "color-dark": "#F2EDE4", "color-light": "#2C2420", "note": "Umbral tipográfico — no colorear con acento" },
      "a":   { "font": "Grantha Sangam MN", "style": "Regular", "color-dark": "#F2EDE4", "color-light": "#2C2420" }
    },
    "reduced": {
      "characters": "pm",
      "use": "32px o menos — favicon, avatar, aplicaciones pequeñas"
    }
  },

  "unitSystem": {
    "description": "El punto vive en el sistema de nomenclatura de unidades, no en el wordmark principal.",
    "separator": { "character": ".", "color": "#D4521A", "font": "Grantha Sangam MN" },
    "suffix-font": "IBM Plex Mono",
    "units": [
      { "name": "pro.pack",  "description": "Unidad de packaging regulado" },
      { "name": "pro.brand", "description": "Unidad de branding" },
      { "name": "pro.web",   "description": "Unidad de diseño web" },
      { "name": "pro.ops",   "description": "Unidad de DesignOps" }
    ],
    "rule": "Las unidades no tienen logo propio. Su identidad es la lógica de nomenclatura."
  },

  "spacing": {
    "base": "4px",
    "scale": {
      "1": "4px", "2": "8px", "3": "12px", "4": "16px",
      "5": "20px", "6": "24px", "8": "32px", "10": "40px",
      "12": "48px", "16": "64px", "20": "80px", "24": "96px"
    }
  },

  "borderRadius": {
    "sm": "3px", "md": "6px", "lg": "12px", "pill": "999px"
  },

  "mode": {
    "rules": {
      "dark": {
        "use": ["Portadas", "Slides de propuesta", "Hero de sitio", "Presentaciones C-level", "Pitches", "Brand deck", "Posts de impacto"],
        "signal": "Impacto · Autoridad · Presentación"
      },
      "light": {
        "use": ["Informes técnicos", "Manuales", "Contratos", "QA", "Emails", "Newsletters", "Changelog", "Release notes"],
        "signal": "Lectura · Proceso · Documentación"
      },
      "master": "La elección de modo es una decisión de diseño, no del usuario. El acento #D4521A es constante en ambos modos. El wordmark proma es siempre monocromático."
    }
  }
}
