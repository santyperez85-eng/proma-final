---
const pilares = [
  {
    nombre: 'Calidad',
    descripcion: 'Criterios de aceptación antes de empezar.',
    detalle: [
      { label: 'Principio', text: 'Nada sale sin criterios de aceptación definidos previamente. Si no sabemos qué es "correcto", no podemos diseñar.' },
      { label: 'En práctica', text: 'Antes de cada entrega definimos qué significa "aprobado". Métricas de legibilidad, consistencia cromática, respeto de grilla y alineación a la estrategia de marca.' },
      { label: 'Resultado', text: 'Menos rondas de revisión. Menos subjetividad. Más velocidad real.' },
    ],
  },
  {
    nombre: 'Documentación',
    descripcion: 'Todo registrado. Si no está documentado, no existe.',
    detalle: [
      { label: 'Principio', text: 'Cada decisión de diseño queda registrada: por qué se eligió, qué se descartó y bajo qué criterio. Si no está documentado, no existe.' },
      { label: 'En práctica', text: 'Manuales de sistema, registros de cambios, bitácoras de proyecto. Cada versión tiene trazabilidad completa.' },
      { label: 'Resultado', text: 'Cualquier persona del equipo puede retomar un proyecto sin perder contexto. La memoria está en el sistema, no en las personas.' },
    ],
  },
  {
    nombre: 'Proceso',
    descripcion: 'Flujos claros, responsables y plazos reales.',
    detalle: [
      { label: 'Principio', text: 'Diseño sin proceso es improvisación disfrazada de creatividad. Cada proyecto tiene flujos definidos, responsables asignados y plazos reales.' },
      { label: 'En práctica', text: 'Kickoff estructurado, checkpoints de revisión, entregables con fecha y responsable. Nada queda "para después".' },
      { label: 'Resultado', text: 'Proyectos que avanzan sin depender de la urgencia. Cumplimiento real de timelines.' },
    ],
  },
  {
    nombre: 'Inteligencia',
    descripcion: 'IA como motor de precisión, no como decoración.',
    detalle: [
      { label: 'Principio', text: 'La inteligencia artificial amplifica el criterio humano. No reemplaza al diseñador — potencia su capacidad de análisis y ejecución.' },
      { label: 'En práctica', text: 'IA para auditoría de consistencia, generación de variantes controladas, optimización de assets y análisis de sistemas gráficos existentes.' },
      { label: 'Resultado', text: 'Mayor precisión en menos tiempo. El criterio humano gobierna, la inteligencia artificial ejecuta.' },
    ],
  },
];
---

<section id="metodo" class="metodo section" data-mode="light">
  <div class="container">
    <header class="metodo-header">
      <span class="type-mono-sm text-accent reveal">REF · FRAMEWORK</span>
      <div class="metodo-title-row reveal">
        <h2 class="metodo-title">PROMA<span class="metodo-dash">-</span>4</h2>
        <p class="type-body metodo-sub">El framework que gobierna<br />cada proyecto.</p>
      </div>
    </header>

    <div class="metodo-grid">
      {pilares.map((p, i) => (
        <div class="pilar-item reveal" data-pilar-toggle>
          <div class="pilar-top">
            <span class="type-mono-sm pilar-index">{String(i + 1).padStart(2, '0')}</span>
            <div class="pilar-bar"></div>
          </div>
          <h3 class="pilar-nombre">{p.nombre}</h3>
          <p class="type-body pilar-desc">{p.descripcion}</p>
          <div class="pilar-expand-icon" aria-hidden="true">
            <span class="expand-line expand-h"></span>
            <span class="expand-line expand-v"></span>
          </div>
          <div class="pilar-detail">
            <div class="pilar-detail-inner">
              {p.detalle.map((d) => (
                <div class="detail-block">
                  <span class="type-mono-sm detail-label">{d.label}</span>
                  <p class="type-body detail-text">{d.text}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .metodo {
    background-color: var(--proma-cream-50);
    color: var(--proma-text-dark);
    border-top: 1px solid var(--proma-cream-200);
  }

  .metodo-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-bottom: clamp(64px, 8vh, 120px);
  }

  .metodo-title-row {
    display: flex;
    align-items: flex-end;
    gap: var(--space-12);
  }

  .metodo-title {
    font-family: var(--font-mono);
    font-size: clamp(48px, 7vw, 100px);
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 0.85;
    color: var(--proma-text-dark);
  }

  .metodo-dash {
    color: var(--proma-terra-500);
  }

  .metodo-sub {
    opacity: 0.4;
    padding-bottom: 8px;
    font-size: 14px;
    line-height: 1.5;
  }

  .metodo-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }

  .pilar-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding: var(--space-8) var(--space-6);
    border: 1px solid var(--proma-cream-200);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    cursor: pointer;
    overflow: hidden;
  }

  .pilar-item:hover {
    border-color: var(--proma-terra-500);
    transform: translateY(-4px);
  }

  .pilar-item.is-expanded {
    border-color: var(--proma-terra-500);
  }

  .pilar-top {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .pilar-bar {
    height: 1px;
    flex: 1;
    background-color: var(--proma-terra-500);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .pilar-item.is-visible .pilar-bar,
  .pilar-item:hover .pilar-bar,
  .pilar-item.is-expanded .pilar-bar {
    transform: scaleX(1);
  }

  .pilar-index {
    color: var(--proma-terra-500);
    flex-shrink: 0;
  }

  .pilar-nombre {
    font-family: var(--font-primary);
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--proma-text-dark);
    transition: color 0.3s ease;
  }

  .pilar-item:hover .pilar-nombre,
  .pilar-item.is-expanded .pilar-nombre {
    color: var(--proma-terra-500);
  }

  .pilar-desc {
    opacity: 0.5;
    font-size: 14px;
    line-height: 1.7;
  }

  /* ── Expand icon ── */
  .pilar-expand-icon {
    position: absolute;
    top: var(--space-6);
    right: var(--space-6);
    width: 16px;
    height: 16px;
  }

  .expand-line {
    position: absolute;
    background-color: var(--proma-terra-500);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
  }

  .expand-h {
    width: 16px;
    height: 1px;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
  }

  .expand-v {
    width: 1px;
    height: 16px;
    left: 50%;
    top: 0;
    transform: translateX(-50%);
  }

  .pilar-item.is-expanded .expand-v {
    transform: translateX(-50%) rotate(90deg);
    opacity: 0;
  }

  /* ── Expandable detail ── */
  .pilar-detail {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .pilar-item.is-expanded .pilar-detail {
    max-height: 500px;
  }

  .pilar-detail-inner {
    padding-top: var(--space-6);
    border-top: 1px solid var(--proma-cream-200);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .detail-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .detail-label {
    color: var(--proma-terra-500);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .detail-text {
    font-size: 13px;
    line-height: 1.7;
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .metodo-grid {
      grid-template-columns: 1fr 1fr;
    }

    .metodo-title-row {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-4);
    }
  }

  @media (max-width: 480px) {
    .metodo-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const pilarItems = document.querySelectorAll('[data-pilar-toggle]');

  pilarItems.forEach((item) => {
    item.addEventListener('click', () => {
      const wasExpanded = item.classList.contains('is-expanded');

      // Close all others
      pilarItems.forEach((other) => other.classList.remove('is-expanded'));

      // Toggle clicked one
      if (!wasExpanded) {
        item.classList.add('is-expanded');
      }
    });
  });
</script>
