---
---

<div class="cursor" id="cursor">
  <div class="cursor-dot"></div>
  <div class="cursor-ring"></div>
</div>

<style is:global>
  /* Hide default cursor on desktop */
  @media (hover: hover) and (pointer: fine) {
    * {
      cursor: none !important;
    }
  }
</style>

<style>
  .cursor {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    z-index: 9999;
    pointer-events: none;
  }

  @media (hover: hover) and (pointer: fine) {
    .cursor {
      display: block;
    }
  }

  .cursor-dot {
    position: absolute;
    width: 6px;
    height: 6px;
    background: var(--proma-cream-100);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: transform 0.15s ease, opacity 0.15s ease;
    mix-blend-mode: difference;
  }

  .cursor-ring {
    position: absolute;
    width: 32px;
    height: 32px;
    border: 1px solid var(--proma-cream-100);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: width 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                height 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.3s ease,
                background-color 0.3s ease,
                opacity 0.3s ease;
    mix-blend-mode: difference;
  }

  /* ── Hover: interactive elements ── */
  .cursor.is-hovering .cursor-ring {
    width: 56px;
    height: 56px;
    border-color: var(--proma-terra-500);
    background-color: rgba(212, 82, 26, 0.1);
  }

  .cursor.is-hovering .cursor-dot {
    transform: translate(-50%, -50%) scale(0);
  }

  /* ── Content hover: invert/umbral effect ── */
  .cursor.is-content .cursor-ring {
    width: 80px;
    height: 80px;
    background-color: #fff;
    border-color: transparent;
    mix-blend-mode: difference;
  }

  .cursor.is-content .cursor-dot {
    opacity: 0;
  }

  /* When both hovering and content, interactive wins */
  .cursor.is-hovering.is-content .cursor-ring {
    width: 56px;
    height: 56px;
    border-color: var(--proma-terra-500);
    background-color: rgba(212, 82, 26, 0.1);
    mix-blend-mode: difference;
  }
</style>

<script>
  const cursor = document.getElementById('cursor');
  if (!cursor) throw new Error('Cursor not found');

  const dot = cursor.querySelector('.cursor-dot') as HTMLElement;
  const ring = cursor.querySelector('.cursor-ring') as HTMLElement;

  let mouseX = 0, mouseY = 0;
  let ringX = 0, ringY = 0;

  document.addEventListener('mousemove', (e) => {
    mouseX = e.clientX;
    mouseY = e.clientY;
    dot.style.left = `${mouseX}px`;
    dot.style.top = `${mouseY}px`;
  });

  // Ring follows with lerp
  function animateRing() {
    ringX += (mouseX - ringX) * 0.15;
    ringY += (mouseY - ringY) * 0.15;
    ring.style.left = `${ringX}px`;
    ring.style.top = `${ringY}px`;
    requestAnimationFrame(animateRing);
  }
  animateRing();

  // Interactive hover detection
  const interactives = 'a, button, input, textarea, [data-cursor-hover]';

  document.addEventListener('mouseover', (e) => {
    if ((e.target as Element).closest(interactives)) {
      cursor.classList.add('is-hovering');
    }
  });

  document.addEventListener('mouseout', (e) => {
    if ((e.target as Element).closest(interactives)) {
      cursor.classList.remove('is-hovering');
    }
  });

  // Content hover — umbral invert effect on headings, text blocks, titles
  const contentSelectors = 'h1, h2, h3, h4, h5, h6, .proyecto-titulo, .trabajo-hero-title, .seccion-titulo, .proyecto-row-titulo, .hero-title, .problema-lead, .problema-conclusion, .estudio-title, .trabajo-title, .contacto-title, .footer-statement, .servicio-nombre, .pilar-nombre, .caso-titulo';

  document.addEventListener('mouseover', (e) => {
    const target = e.target as Element;
    if (target.closest(contentSelectors) && !target.closest(interactives)) {
      cursor.classList.add('is-content');
    }
  });

  document.addEventListener('mouseout', (e) => {
    const target = e.target as Element;
    if (target.closest(contentSelectors)) {
      cursor.classList.remove('is-content');
    }
  });

  // Hide cursor when leaving window
  document.addEventListener('mouseleave', () => {
    cursor.style.opacity = '0';
  });
  document.addEventListener('mouseenter', () => {
    cursor.style.opacity = '1';
  });
</script>
