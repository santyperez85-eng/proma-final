---
---

<section id="contacto" class="contacto section" data-mode="dark">
  <div class="contacto-glow"></div>

  <!-- Registration marks -->
  <div class="reg-mark reg-tl" aria-hidden="true"></div>
  <div class="reg-mark reg-tr" aria-hidden="true"></div>

  <div class="container contacto-container">
    <div class="contacto-left">
      <span class="type-mono-sm text-accent reveal">REF · DIAGNÓSTICO INICIAL</span>
      <h2 class="contacto-title reveal">
        ¿Cuánto le cuesta el <em class="contacto-italic">desorden</em> a tu organización?
      </h2>
      <p class="type-body contacto-sub reveal">
        El primer paso es un diagnóstico. Entendemos tu situación,
        identificamos los puntos críticos y te decimos con precisión
        qué necesitás. Sin compromiso. Con criterio.
      </p>
    </div>

    <form class="contacto-form reveal" id="contacto-form">
      <div class="form-grid">
        <div class="form-field">
          <label for="nombre" class="type-mono-sm">Nombre</label>
          <input type="text" id="nombre" name="nombre" required autocomplete="name" />
        </div>
        <div class="form-field">
          <label for="empresa" class="type-mono-sm">Empresa</label>
          <input type="text" id="empresa" name="empresa" autocomplete="organization" />
        </div>
        <div class="form-field">
          <label for="industria" class="type-mono-sm">Industria</label>
          <input type="text" id="industria" name="industria" />
        </div>
        <div class="form-field">
          <label for="email" class="type-mono-sm">Email</label>
          <input type="email" id="email" name="email" required autocomplete="email" />
        </div>
      </div>
      <div class="form-field form-field-full">
        <label for="desafio" class="type-mono-sm">Desafío</label>
        <textarea id="desafio" name="desafio" rows="3"></textarea>
      </div>

      <div class="form-footer">
        <button type="submit" class="btn-cta contacto-cta" id="contacto-btn" data-cursor-hover>
          <span class="btn-text">Agendá un diagnóstico</span>
          <span class="btn-sending" aria-hidden="true">Enviando...</span>
        </button>
        <div class="form-status" id="form-status" aria-live="polite"></div>
      </div>
    </form>
  </div>
</section>

<style>
  .contacto {
    background-color: var(--proma-navy-900);
    color: var(--proma-cream-100);
    border-top: 1px solid var(--proma-navy-700);
    position: relative;
    overflow: hidden;
  }

  .contacto-glow {
    position: absolute;
    top: -30%;
    left: 30%;
    width: 50vw;
    height: 50vw;
    background: radial-gradient(circle, rgba(212, 82, 26, 0.04) 0%, transparent 70%);
    pointer-events: none;
  }

  .contacto-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(48px, 6vw, 96px);
    align-items: start;
    position: relative;
    z-index: 1;
  }

  .contacto-left {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    position: sticky;
    top: 120px;
  }

  .contacto-title {
    font-family: var(--font-primary);
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .contacto-italic {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 400;
    color: var(--proma-terra-500);
    text-shadow: 0 0 25px rgba(212, 82, 26, 0.2), 0 0 50px rgba(212, 82, 26, 0.06);
  }

  .contacto-sub {
    opacity: 0.4;
    font-size: 14px;
    line-height: 1.7;
  }

  .contacto-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .form-field label {
    color: var(--proma-cream-100);
    opacity: 0.3;
    font-size: 10px;
  }

  .form-field input,
  .form-field textarea {
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(242, 237, 228, 0.1);
    color: var(--proma-cream-100);
    font-family: var(--font-primary);
    font-size: 15px;
    padding: var(--space-3) 0;
    outline: none;
    transition: border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .form-field input:focus,
  .form-field textarea:focus {
    border-bottom-color: var(--proma-terra-500);
  }

  .form-field textarea {
    resize: vertical;
    min-height: 60px;
  }

  /* ── Status + CTA wrapper ── */
  .form-footer {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    margin-top: var(--space-4);
  }

  /* ── Submit button states ── */
  .contacto-cta {
    padding: var(--space-3) var(--space-8);
    font-size: 11px;
    position: relative;
    flex-shrink: 0;
  }

  .btn-sending {
    display: none;
  }

  .contacto-cta.is-sending .btn-text {
    display: none;
  }

  .contacto-cta.is-sending .btn-sending {
    display: inline;
  }

  .contacto-cta.is-sending {
    opacity: 0.6;
    pointer-events: none;
  }

  .contacto-cta.is-sent {
    background-color: transparent;
    border: 1px solid rgba(242, 237, 228, 0.15);
    color: var(--proma-cream-100);
    pointer-events: none;
  }

  /* ── Status message ── */
  .form-status {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    line-height: 1.4;
    opacity: 0;
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .form-status.is-visible {
    opacity: 1;
  }

  .form-status.is-success {
    color: var(--proma-cream-100);
    opacity: 0.5;
  }

  .form-status.is-error {
    color: var(--proma-terra-500);
  }

  @media (max-width: 768px) {
    .contacto-container {
      grid-template-columns: 1fr;
    }

    .contacto-left {
      position: static;
    }

    .form-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const SUPABASE_URL = 'https://qsqtbyztotiqlskwnpyj.supabase.co';
  const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFzcXRieXp0b3RpcWxza3ducHlqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQyMTU3NDEsImV4cCI6MjA4OTc5MTc0MX0.1XDX_VQm_XSBcavV7GvTaOO9XsoCu3bwfkOG1x35hZ8';

  const form = document.getElementById('contacto-form') as HTMLFormElement;
  const btn = document.getElementById('contacto-btn')!;
  const status = document.getElementById('form-status')!;

  function showStatus(message: string, type: 'success' | 'error') {
    status.textContent = message;
    status.className = `form-status is-visible is-${type}`;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Collect form data
    const data = {
      nombre: (form.querySelector('#nombre') as HTMLInputElement).value.trim(),
      empresa: (form.querySelector('#empresa') as HTMLInputElement).value.trim(),
      industria: (form.querySelector('#industria') as HTMLInputElement).value.trim(),
      email: (form.querySelector('#email') as HTMLInputElement).value.trim(),
      desafio: (form.querySelector('#desafio') as HTMLTextAreaElement).value.trim(),
    };

    // Basic validation
    if (!data.nombre || !data.email) {
      showStatus('Completá al menos nombre y email.', 'error');
      return;
    }

    // UI: sending state
    btn.classList.add('is-sending');
    status.className = 'form-status';

    try {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/contacto`, {
        method: 'POST',
        headers: {
          'apikey': SUPABASE_ANON_KEY,
          'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
          'Content-Type': 'application/json',
          'Prefer': 'return=minimal',
        },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        showStatus('Recibido. Nos ponemos en contacto pronto.', 'success');
        btn.classList.remove('is-sending');
        btn.classList.add('is-sent');
        (btn.querySelector('.btn-text') as HTMLElement).textContent = 'Enviado';
        form.reset();
      } else {
        const err = await res.json().catch(() => null);
        console.error('Supabase error:', res.status, err);
        showStatus('Error al enviar. Intentá de nuevo o escribinos a hola@pro.ma', 'error');
        btn.classList.remove('is-sending');
      }
    } catch (err) {
      console.error('Network error:', err);
      showStatus('Error de conexión. Intentá de nuevo.', 'error');
      btn.classList.remove('is-sending');
    }
  });
</script>
