---
---

<section class="problema section" data-mode="dark" id="problema-section">
  <div class="problema-glow"></div>
  <div class="container problema-container">
    <div class="problema-lead">
      <p class="problema-lead-text scroll-reveal-text">
        El diseño sin proceso tiene un costo medible.
      </p>
    </div>

    <div class="problema-body">
      <div class="problema-accent-bar reveal-line"></div>
      <div class="problema-texts">
        <p class="type-body problema-text scroll-reveal-text">
          Retrabajos que se repiten. Cambios sin registro.
          Aprobaciones sin criterio. Entregas que vuelven.
        </p>

        <p class="type-body problema-text scroll-reveal-text">
          No es un problema de talento.
          <strong>Es un problema de sistema.</strong>
        </p>

        <p class="type-body problema-text scroll-reveal-text">
          Lo sabemos porque venimos del entorno donde ese problema
          tiene consecuencias reales: <em>industrias reguladas</em>,
          donde cada error detiene una línea de producción,
          frena un lanzamiento o falla una auditoría.
        </p>

        <p class="type-body problema-text scroll-reveal-text">
          Cuarenta años combinados trabajando en ese límite
          nos enseñaron una sola cosa:
        </p>
      </div>
    </div>

    <div class="problema-conclusion">
      <p class="conclusion-line conclusion-muted scroll-reveal-text">Sin proceso, el diseño falla.</p>
      <p class="conclusion-line conclusion-strong scroll-reveal-text">Con proceso, <em class="conclusion-italic">escala</em><span class="text-accent">.</span></p>
    </div>
  </div>
</section>

<style>
  .problema {
    background-color: var(--proma-navy-900);
    color: var(--proma-cream-100);
    position: relative;
    overflow: hidden;
  }

  .problema-glow {
    position: absolute;
    bottom: -30%;
    left: -20%;
    width: 60vw;
    height: 60vw;
    background: radial-gradient(
      ellipse at center,
      rgba(212, 82, 26, 0.06) 0%,
      rgba(180, 60, 20, 0.03) 40%,
      transparent 70%
    );
    pointer-events: none;
  }

  .problema::after {
    content: '';
    position: absolute;
    top: -20%;
    right: -15%;
    width: 50vw;
    height: 50vw;
    background: radial-gradient(
      ellipse at center,
      rgba(120, 80, 200, 0.03) 0%,
      rgba(80, 50, 140, 0.01) 40%,
      transparent 65%
    );
    pointer-events: none;
  }

  .problema-container {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: clamp(48px, 8vh, 96px);
  }

  /* ── Lead title ── */
  .problema-lead-text {
    font-family: var(--font-primary);
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  /* ── Body ── */
  .problema-body {
    display: flex;
    gap: var(--space-8);
    max-width: 680px;
  }

  .problema-accent-bar {
    width: 3px;
    min-height: 100%;
    background-color: var(--proma-terra-500);
    flex-shrink: 0;
  }

  .problema-texts {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .problema-text {
    color: var(--proma-cream-100);
    font-size: 15px;
    line-height: 1.8;
  }

  /* ── Word-by-word reveal: global spans ── */
  :global(.reveal-word) {
    opacity: 0.15;
    transition: opacity 0.05s ease-out;
  }

  :global(.reveal-word.is-lit) {
    opacity: 1;
  }

  .problema-lead-text :global(.reveal-word) {
    color: var(--proma-cream-100);
    opacity: 0.08;
  }

  .problema-lead-text :global(.reveal-word.is-lit) {
    opacity: 0.5;
  }

  .problema-text :global(.reveal-word) {
    color: var(--proma-cream-100);
    opacity: 0.1;
  }

  .problema-text :global(.reveal-word.is-lit) {
    opacity: 1;
  }

  .problema-text strong {
    color: var(--proma-cream-100);
    font-weight: 600;
  }

  .problema-text em {
    color: var(--proma-terra-500);
    font-style: normal;
  }

  .problema-text em :global(.reveal-word) {
    color: var(--proma-terra-500);
  }

  .problema-text em :global(.reveal-word.is-lit) {
    color: var(--proma-terra-500);
    opacity: 1;
  }

  /* ── Conclusion ── */
  .problema-conclusion {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .conclusion-line {
    font-family: var(--font-primary);
    font-size: clamp(32px, 5vw, 64px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .conclusion-muted :global(.reveal-word) {
    color: var(--proma-cream-100);
    opacity: 0.06;
  }

  .conclusion-muted :global(.reveal-word.is-lit) {
    opacity: 0.25;
  }

  .conclusion-strong :global(.reveal-word) {
    color: var(--proma-cream-100);
    opacity: 0.06;
  }

  .conclusion-strong :global(.reveal-word.is-lit) {
    opacity: 1;
    text-shadow: 0 0 40px rgba(212, 82, 26, 0.15), 0 0 80px rgba(212, 82, 26, 0.05);
  }

  .conclusion-italic {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 400;
  }

  .conclusion-italic :global(.reveal-word) {
    color: var(--proma-terra-500);
  }

  .conclusion-italic :global(.reveal-word.is-lit) {
    color: var(--proma-terra-500);
    opacity: 1;
    text-shadow: 0 0 30px rgba(212, 82, 26, 0.3), 0 0 70px rgba(212, 82, 26, 0.1);
  }

  .text-accent {
    color: var(--proma-terra-500);
  }

  .text-accent :global(.reveal-word) {
    color: var(--proma-terra-500);
  }

  .text-accent :global(.reveal-word.is-lit) {
    color: var(--proma-terra-500);
    opacity: 1;
  }

  @media (max-width: 768px) {
    .problema-body {
      flex-direction: column;
    }

    .problema-accent-bar {
      width: 100%;
      height: 3px;
      min-height: auto;
    }
  }
</style>

<script>
  function initProblemaScrollReveal() {
    // Select ALL scroll-reveal-text elements in the section (lead + body + conclusion)
    const allRevealElements = document.querySelectorAll('#problema-section .scroll-reveal-text');
    if (!allRevealElements.length) return;

    // Wrap words in all of them
    allRevealElements.forEach((el) => {
      wrapWordsInElement(el as HTMLElement);
    });

    // Collect all words in order across the entire section
    const allWords = document.querySelectorAll('#problema-section .reveal-word');
    const totalWords = allWords.length;

    function updateReveal() {
      const viewportHeight = window.innerHeight;
      const section = document.getElementById('problema-section');
      if (!section) return;

      const rect = section.getBoundingClientRect();
      const sectionHeight = rect.height;

      // Delay: start revealing when the section top reaches 65% of viewport (not immediately)
      // Finish: all words lit by the time section has scrolled ~60% of its height
      const startTrigger = viewportHeight * 0.65;

      // How far the section has scrolled past the start trigger
      const scrolled = startTrigger - rect.top;
      // Finish all reveals within 55% of the section height — so it ends well
      // before the conclusion reaches the top of the screen
      const totalTravel = sectionHeight * 0.55;

      const progress = scrolled / totalTravel;
      const clampedProgress = Math.max(0, Math.min(1, progress));

      // Map progress to word index — binary reveal
      const litCount = Math.floor(clampedProgress * totalWords);

      allWords.forEach((word, i) => {
        if (i < litCount) {
          word.classList.add('is-lit');
        } else {
          word.classList.remove('is-lit');
        }
      });
    }

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          updateReveal();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    updateReveal();
  }

  // Recursively wrap text nodes in word spans, preserving child elements
  function wrapWordsInElement(el: HTMLElement) {
    const children = Array.from(el.childNodes);
    children.forEach((node) => {
      if (node.nodeType === Node.TEXT_NODE) {
        const text = node.textContent || '';
        if (text.trim() === '') return;
        const fragment = document.createDocumentFragment();
        const parts = text.split(/(\s+)/);
        parts.forEach((part) => {
          if (part.match(/^\s+$/)) {
            fragment.appendChild(document.createTextNode(part));
          } else if (part.length > 0) {
            const span = document.createElement('span');
            span.className = 'reveal-word';
            span.textContent = part;
            fragment.appendChild(span);
          }
        });
        el.replaceChild(fragment, node);
      } else if (node.nodeType === Node.ELEMENT_NODE) {
        wrapWordsInElement(node as HTMLElement);
      }
    });
  }

  initProblemaScrollReveal();
</script>
