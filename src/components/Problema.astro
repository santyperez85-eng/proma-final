---
---

<section class="problema section" data-mode="dark">
  <div class="problema-glow"></div>
  <div class="container problema-container">
    <div class="problema-lead">
      <p class="reveal" style="font-family: var(--font-primary); font-size: clamp(28px, 4vw, 52px); font-weight: 700; line-height: 1.1; letter-spacing: -0.03em; opacity: 0.35;">
        El diseño sin proceso tiene un costo medible.
      </p>
    </div>

    <div class="problema-body">
      <div class="problema-accent-bar reveal-line"></div>
      <div class="problema-texts" id="problema-scroll-reveal">
        <p class="type-body problema-text scroll-reveal-text">
          Retrabajos que se repiten. Cambios sin registro.<br />
          Aprobaciones sin criterio. Entregas que vuelven.
        </p>

        <p class="type-body problema-text scroll-reveal-text">
          No es un problema de talento.<br />
          <strong>Es un problema de sistema.</strong>
        </p>

        <p class="type-body problema-text scroll-reveal-text">
          Lo sabemos porque venimos del entorno donde ese problema
          tiene consecuencias reales: <em>industrias reguladas</em>,
          donde cada error detiene una línea de producción,
          frena un lanzamiento o falla una auditoría.
        </p>

        <p class="type-body problema-text scroll-reveal-text">
          Cuarenta años combinados trabajando en ese límite
          nos enseñaron una sola cosa:
        </p>
      </div>
    </div>

    <div class="problema-conclusion reveal">
      <p class="conclusion-line conclusion-muted">Sin proceso, el diseño falla.</p>
      <p class="conclusion-line conclusion-strong">Con proceso, <em class="conclusion-italic">escala</em><span class="text-accent">.</span></p>
    </div>
  </div>
</section>

<style>
  .problema {
    background-color: var(--proma-navy-900);
    color: var(--proma-cream-100);
    position: relative;
    overflow: hidden;
  }

  .problema-glow {
    position: absolute;
    bottom: -30%;
    left: -20%;
    width: 60vw;
    height: 60vw;
    background: radial-gradient(
      ellipse at center,
      rgba(212, 82, 26, 0.06) 0%,
      rgba(180, 60, 20, 0.03) 40%,
      transparent 70%
    );
    pointer-events: none;
  }

  .problema::after {
    content: '';
    position: absolute;
    top: -20%;
    right: -15%;
    width: 50vw;
    height: 50vw;
    background: radial-gradient(
      ellipse at center,
      rgba(120, 80, 200, 0.03) 0%,
      rgba(80, 50, 140, 0.01) 40%,
      transparent 65%
    );
    pointer-events: none;
  }

  .problema-container {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: clamp(48px, 8vh, 96px);
  }

  .problema-body {
    display: flex;
    gap: var(--space-8);
    max-width: 680px;
  }

  .problema-accent-bar {
    width: 3px;
    min-height: 100%;
    background-color: var(--proma-terra-500);
    flex-shrink: 0;
  }

  .problema-texts {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .problema-text {
    color: var(--proma-cream-100);
    opacity: 0.15;
    font-size: 15px;
    line-height: 1.8;
    transition: opacity 0.1s ease-out;
  }

  .problema-text.is-revealed {
    opacity: 1;
  }

  .problema-text strong {
    color: var(--proma-cream-100);
    font-weight: 600;
  }

  .problema-text em {
    color: var(--proma-terra-500);
    font-style: normal;
  }

  .problema-conclusion {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .conclusion-line {
    font-family: var(--font-primary);
    font-size: clamp(32px, 5vw, 64px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .conclusion-muted {
    opacity: 0.2;
  }

  .conclusion-strong {
    color: var(--proma-cream-100);
    text-shadow: 0 0 40px rgba(212, 82, 26, 0.15), 0 0 80px rgba(212, 82, 26, 0.05);
  }

  .conclusion-italic {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 400;
    color: var(--proma-terra-500);
    text-shadow: 0 0 30px rgba(212, 82, 26, 0.3), 0 0 70px rgba(212, 82, 26, 0.1);
  }

  .text-accent {
    color: var(--proma-terra-500);
  }

  @media (max-width: 768px) {
    .problema-body {
      flex-direction: column;
    }

    .problema-accent-bar {
      width: 100%;
      height: 3px;
      min-height: auto;
    }
  }
</style>

<script>
  function initProblemaScrollReveal() {
    const texts = document.querySelectorAll('.scroll-reveal-text');
    if (!texts.length) return;

    function updateReveal() {
      const viewportHeight = window.innerHeight;

      texts.forEach((el) => {
        const rect = el.getBoundingClientRect();
        // Start revealing when element enters bottom 85% of viewport
        // Fully revealed when element reaches 45% of viewport
        const startPoint = viewportHeight * 0.85;
        const endPoint = viewportHeight * 0.45;

        if (rect.top <= startPoint && rect.top >= endPoint) {
          // Map position to 0–1 progress
          const progress = 1 - (rect.top - endPoint) / (startPoint - endPoint);
          const opacity = 0.15 + progress * 0.85;
          (el as HTMLElement).style.opacity = String(opacity);
          el.classList.toggle('is-revealed', progress >= 0.95);
        } else if (rect.top < endPoint) {
          (el as HTMLElement).style.opacity = '1';
          el.classList.add('is-revealed');
        } else {
          (el as HTMLElement).style.opacity = '0.15';
          el.classList.remove('is-revealed');
        }
      });
    }

    // Use requestAnimationFrame for smooth scroll performance
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          updateReveal();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    // Initial check
    updateReveal();
  }

  initProblemaScrollReveal();
</script>
