---
---

<section class="problema section" data-mode="dark">
  <div class="problema-glow"></div>
  <div class="container problema-container">
    <div class="problema-lead">
      <p class="reveal" style="font-family: var(--font-primary); font-size: clamp(28px, 4vw, 52px); font-weight: 700; line-height: 1.1; letter-spacing: -0.03em; opacity: 0.35;">
        El diseño sin proceso tiene un costo medible.
      </p>
    </div>

    <div class="problema-body">
      <div class="problema-accent-bar reveal-line"></div>
      <div class="problema-texts" id="problema-scroll-reveal">
        <p class="type-body problema-text scroll-reveal-text">
          Retrabajos que se repiten. Cambios sin registro.
          Aprobaciones sin criterio. Entregas que vuelven.
        </p>

        <p class="type-body problema-text scroll-reveal-text">
          No es un problema de talento.
          <strong>Es un problema de sistema.</strong>
        </p>

        <p class="type-body problema-text scroll-reveal-text">
          Lo sabemos porque venimos del entorno donde ese problema
          tiene consecuencias reales: <em>industrias reguladas</em>,
          donde cada error detiene una línea de producción,
          frena un lanzamiento o falla una auditoría.
        </p>

        <p class="type-body problema-text scroll-reveal-text">
          Cuarenta años combinados trabajando en ese límite
          nos enseñaron una sola cosa:
        </p>
      </div>
    </div>

    <div class="problema-conclusion reveal">
      <p class="conclusion-line conclusion-muted">Sin proceso, el diseño falla.</p>
      <p class="conclusion-line conclusion-strong">Con proceso, <em class="conclusion-italic">escala</em><span class="text-accent">.</span></p>
    </div>
  </div>
</section>

<style>
  .problema {
    background-color: var(--proma-navy-900);
    color: var(--proma-cream-100);
    position: relative;
    overflow: hidden;
  }

  .problema-glow {
    position: absolute;
    bottom: -30%;
    left: -20%;
    width: 60vw;
    height: 60vw;
    background: radial-gradient(
      ellipse at center,
      rgba(212, 82, 26, 0.06) 0%,
      rgba(180, 60, 20, 0.03) 40%,
      transparent 70%
    );
    pointer-events: none;
  }

  .problema::after {
    content: '';
    position: absolute;
    top: -20%;
    right: -15%;
    width: 50vw;
    height: 50vw;
    background: radial-gradient(
      ellipse at center,
      rgba(120, 80, 200, 0.03) 0%,
      rgba(80, 50, 140, 0.01) 40%,
      transparent 65%
    );
    pointer-events: none;
  }

  .problema-container {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: clamp(48px, 8vh, 96px);
  }

  .problema-body {
    display: flex;
    gap: var(--space-8);
    max-width: 680px;
  }

  .problema-accent-bar {
    width: 3px;
    min-height: 100%;
    background-color: var(--proma-terra-500);
    flex-shrink: 0;
  }

  .problema-texts {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .problema-text {
    color: var(--proma-cream-100);
    font-size: 15px;
    line-height: 1.8;
  }

  /* Word-by-word reveal: each word starts muted */
  .problema-text :global(.reveal-word) {
    color: var(--proma-cream-100);
    opacity: 0.15;
    transition: opacity 0.05s ease-out;
  }

  .problema-text :global(.reveal-word.is-lit) {
    opacity: 1;
  }

  .problema-text strong {
    color: var(--proma-cream-100);
    font-weight: 600;
  }

  .problema-text strong :global(.reveal-word.is-lit) {
    opacity: 1;
  }

  .problema-text em {
    color: var(--proma-terra-500);
    font-style: normal;
  }

  .problema-text em :global(.reveal-word.is-lit) {
    color: var(--proma-terra-500);
    opacity: 1;
  }

  .problema-conclusion {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .conclusion-line {
    font-family: var(--font-primary);
    font-size: clamp(32px, 5vw, 64px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .conclusion-muted {
    opacity: 0.2;
  }

  .conclusion-strong {
    color: var(--proma-cream-100);
    text-shadow: 0 0 40px rgba(212, 82, 26, 0.15), 0 0 80px rgba(212, 82, 26, 0.05);
  }

  .conclusion-italic {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 400;
    color: var(--proma-terra-500);
    text-shadow: 0 0 30px rgba(212, 82, 26, 0.3), 0 0 70px rgba(212, 82, 26, 0.1);
  }

  .text-accent {
    color: var(--proma-terra-500);
  }

  @media (max-width: 768px) {
    .problema-body {
      flex-direction: column;
    }

    .problema-accent-bar {
      width: 100%;
      height: 3px;
      min-height: auto;
    }
  }
</style>

<script>
  function initProblemaScrollReveal() {
    const paragraphs = document.querySelectorAll('.scroll-reveal-text');
    if (!paragraphs.length) return;

    // Wrap each text node's words in spans, preserving existing HTML elements
    paragraphs.forEach((p) => {
      wrapWordsInElement(p as HTMLElement);
    });

    const allWords = document.querySelectorAll('.reveal-word');
    const totalWords = allWords.length;

    function updateReveal() {
      const viewportHeight = window.innerHeight;
      const container = document.getElementById('problema-scroll-reveal');
      if (!container) return;

      const rect = container.getBoundingClientRect();
      // The reveal zone: from when container enters bottom 90% to when it's at 25%
      const startPoint = viewportHeight * 0.95;
      const endPoint = viewportHeight * 0.2;
      const range = startPoint - endPoint;

      // Calculate overall progress based on container position
      // Use center-ish of container for smoother tracking
      const containerProgress = 1 - (rect.top - endPoint) / range;
      const clampedProgress = Math.max(0, Math.min(1, containerProgress));

      // Map progress to word index — binary: word is either lit or not
      const litCount = Math.floor(clampedProgress * totalWords);

      allWords.forEach((word, i) => {
        if (i < litCount) {
          word.classList.add('is-lit');
        } else {
          word.classList.remove('is-lit');
        }
      });
    }

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          updateReveal();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    updateReveal();
  }

  // Recursively wrap text nodes in word spans, preserving child elements
  function wrapWordsInElement(el: HTMLElement) {
    const children = Array.from(el.childNodes);
    children.forEach((node) => {
      if (node.nodeType === Node.TEXT_NODE) {
        const text = node.textContent || '';
        if (text.trim() === '') return;
        const fragment = document.createDocumentFragment();
        // Split preserving whitespace
        const parts = text.split(/(\s+)/);
        parts.forEach((part) => {
          if (part.match(/^\s+$/)) {
            fragment.appendChild(document.createTextNode(part));
          } else if (part.length > 0) {
            const span = document.createElement('span');
            span.className = 'reveal-word';
            span.textContent = part;
            fragment.appendChild(span);
          }
        });
        el.replaceChild(fragment, node);
      } else if (node.nodeType === Node.ELEMENT_NODE) {
        // Recurse into child elements (strong, em, etc.)
        wrapWordsInElement(node as HTMLElement);
      }
    });
  }

  initProblemaScrollReveal();
</script>
