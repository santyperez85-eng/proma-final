---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';

const servicios = [
  {
    id: 'diagnostico',
    ref: '01',
    nombre: 'Diagnóstico & Consultoría',
    tagline: 'La entrada a todo proyecto.',
    paraQuien: [
      'Organizaciones que saben que algo no funciona pero no tienen claro dónde está el problema.',
      'Gerentes de calidad, directores de marketing, COOs que heredaron un sistema de diseño que nadie entiende del todo.',
      'O equipos que están por lanzar algo importante y quieren asegurarse de que el proceso no va a fallar en el momento que importa.',
    ],
    queResuelve: [
      'El desorden que no se ve pero que se paga: rondas de revisión que no terminan, archivos sin versión, decisiones sin criterio, equipos que no pueden trabajar sin el diseñador original en la sala.',
    ],
    queIncluye: [
      'Auditoría del sistema visual existente',
      'Mapeo de fricciones y puntos de falla',
      'Análisis del proceso de aprobación actual',
      'Roadmap técnico con prioridades',
      'Documento de diagnóstico para uso interno',
    ],
    adicionales: [],
    comoEmpieza: [
      'Una reunión de 60 minutos. Escuchamos, preguntamos, registramos. Después auditamos lo que tenés.',
      'En 5 días laborales tenés el resultado. El costo del diagnóstico se imputa al proyecto si decidís continuar trabajando juntos.',
    ],
    inversion: 'Los diagnósticos son de tarifa fija. Consultá disponibilidad y costo actual en el formulario de contacto.',
  },
  {
    id: 'packaging',
    ref: '02',
    nombre: 'Packaging',
    tagline: 'Gráfico · Estructural · Regulatorio',
    paraQuien: [
      'Equipos de marketing, regulatory affairs o producción que necesitan piezas que funcionen en planta, cumplan normativa y no requieran interpretación para reproducirse.',
      'Y para quienes ya tuvieron el problema contrario: el packaging que volvió tres veces porque "no se entiende cuál versión es la final".',
    ],
    queResuelve: [
      'Venimos de entornos donde un error de packaging tiene consecuencias reales: auditorías, retiros, relanzamientos. Eso nos enseñó a diseñar piezas que no necesitan interpretación.',
      'Cada archivo entregado incluye sus especificaciones técnicas de producción. Cada versión tiene número y registro. Tu equipo — o el próximo estudio que contrates — puede retomar sin llamarnos.',
    ],
    queIncluye: [
      'Diseño gráfico de packaging',
      'Especificaciones técnicas de producción',
      'Tolerancias, sangrados y marcas de corte',
      'Control de archivos y versiones',
      'Revisión de compliance regulatorio aplicable',
      'Manual de producción del producto terminado',
    ],
    adicionales: [
      'Diseño estructural y desarrollo de envase',
      'Literaturas y materiales de acompañamiento',
      'Gestión y acompañamiento en aprobaciones regulatorias',
      'Adaptaciones y extensiones de línea',
      'Artworks listos para impresión',
    ],
    comoEmpieza: [
      'Con el diagnóstico, o directamente con un brief técnico si ya sabés lo que necesitás.',
      'Los proyectos de packaging se cierran por alcance — no por horas. Sabés desde el inicio qué incluye y cuándo lo recibís.',
    ],
  },
  {
    id: 'branding',
    ref: '03',
    nombre: 'Branding',
    tagline: 'Identidad · Sistema · Aplicaciones',
    paraQuien: [
      'Organizaciones que necesitan una identidad que funcione sin depender de quienes la crearon.',
      'Empresas que escalan y necesitan coherencia. Equipos que cambiaron y ya nadie sabe "cómo se usaba el logo antes". Marcas que crecieron y la identidad quedó chica o inconsistente.',
    ],
    queResuelve: [
      'Una identidad exitosa es la que funciona cuando el diseñador no está en la sala.',
      'Construimos sistemas de marca documentados: la identidad visual, las reglas de uso, los criterios de decisión y los archivos maestros organizados.',
      'Tu equipo puede aplicarla. Tu próxima agencia puede continuarla. Sin llamarnos para preguntar.',
    ],
    queIncluye: [
      'Desarrollo de identidad visual completa',
      'Sistema de marca con criterios de aplicación',
      'Manual de uso con casos prácticos documentados',
      'Archivos maestros organizados y versionados',
      'Guía para equipos internos y proveedores externos',
    ],
    adicionales: [
      'Señalética y ambientación de espacios',
      'Diseño de stands y presencia física',
      'Motion y animación de marca',
      'Extensiones del sistema a submarcas o unidades',
      'Aplicaciones específicas de industria',
    ],
    comoEmpieza: [],
  },
  {
    id: 'web',
    ref: '04',
    nombre: 'Web & Aplicaciones',
    tagline: 'Sitios · Plataformas · UX/UI',
    paraQuien: [
      'Organizaciones que necesitan presencia digital coherente con su identidad y funcional para sus usuarios.',
      'Desde el sitio institucional hasta plataformas de gestión interna. Lo que tienen en común: necesitan funcionar bien, verse bien y poder ser mantenidos por el equipo que viene después.',
    ],
    queResuelve: [
      'El problema de la mayoría de los sitios y apps no es estético — es que no tienen sistema. Cada actualización rompe algo. Cada nuevo desarrollador empieza de cero.',
      'Diseñamos con arquitectura documentada: componentes definidos, criterios de UX registrados, lógica de decisión explícita. El siguiente equipo técnico puede trabajar sobre lo que construimos sin necesitar que estemos presentes.',
    ],
    queIncluye: [
      'Arquitectura de información y flujos UX',
      'Diseño de interfaces',
      'Prototipo funcional validado',
      'Sistema de componentes documentado',
      'Handoff técnico para desarrollo',
    ],
    adicionales: [
      'Desarrollo front-end',
      'Integración con plataformas existentes',
      'Testing con usuarios reales',
      'Diseño de apps mobile',
      'Sistemas de gestión de contenido',
    ],
    comoEmpieza: [],
  },
  {
    id: 'retainer',
    ref: '05',
    nombre: 'Mantenimiento & Retainer',
    tagline: 'El sistema vivo',
    paraQuien: [
      'Organizaciones que tienen un sistema de diseño que quieren mantener vivo sin depender de contratar un estudio nuevo cada vez que algo cambia.',
      'O que acaban de cerrar un proyecto con nosotros y quieren asegurarse de que lo que construimos siga funcionando a medida que la organización crece.',
    ],
    queResuelve: [],
    queIncluye: [
      'QA mensual del sistema visual',
      'Control de versiones y changelog documentado',
      'Actualizaciones y adaptaciones al sistema',
      'Soporte técnico con SLA definido por contrato',
      'Reporte mensual del estado del sistema',
    ],
    adicionales: [],
    comoEmpieza: [
      'Abono mensual con alcance definido por contrato. Renovable. Sin permanencia mínima obligatoria.',
      'Los proyectos nuevos se cotizan aparte. El retainer cubre el mantenimiento del sistema existente — no el desarrollo de piezas nuevas fuera del alcance acordado.',
    ],
  },
];
---

<Base title="Servicios — pro.ma Studio">

  <!-- ═══ HERO (compact) ═══ -->
  <section class="serv-hero" data-mode="dark">
    <div class="serv-hero-glow"></div>
    <div class="reg-mark reg-tl" aria-hidden="true"></div>
    <div class="reg-mark reg-tr" aria-hidden="true"></div>
    <div class="container">
      <span class="type-mono-sm text-accent reveal">REF · SERVICIOS · v1.0</span>
      <h1 class="serv-hero-title reveal">
        No creamos dependencia.<br />
        Construimos sistemas que funcionan<br />
        sin que tengamos que estar <em class="serv-hero-italic">presentes</em><span class="text-accent">.</span>
      </h1>
      <div class="serv-hero-bottom reveal">
        <div class="serv-hero-bar"></div>
        <p class="type-body serv-hero-sub">
          Antes de cualquier proyecto, hay un diagnóstico.
          No para venderte más — para entender qué necesitás.
          A veces el problema es de diseño. A veces es de proceso.
          A veces es de documentación. <strong>Siempre es medible.</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ SERVICES LIST ═══ -->
  <section class="serv-list-section" data-mode="dark">
    <div class="serv-list-glow"></div>
    <div class="container">
      {servicios.map((s) => (
        <article class="serv-item reveal" id={s.id} data-serv-toggle>
          <!-- Collapsed row -->
          <div class="serv-row">
            <span class="type-mono-sm serv-ref">{s.ref} →</span>
            <h2 class="serv-nombre">{s.nombre}</h2>
            <span class="type-mono-sm serv-tagline">{s.tagline}</span>
            <div class="serv-toggle" aria-hidden="true">
              <span class="toggle-h"></span>
              <span class="toggle-v"></span>
            </div>
          </div>

          <!-- Expanded detail -->
          <div class="serv-detail">
            <div class="serv-detail-inner">
              <!-- Top: context columns -->
              <div class="serv-context">
                {s.paraQuien.length > 0 && (
                  <div class="serv-context-col">
                    <span class="type-mono-sm serv-label">Para quién es</span>
                    {s.paraQuien.map((p) => (
                      <p class="type-body serv-text">{p}</p>
                    ))}
                  </div>
                )}
                {s.queResuelve.length > 0 && (
                  <div class="serv-context-col">
                    <span class="type-mono-sm serv-label">Qué problema resuelve</span>
                    {s.queResuelve.map((p) => (
                      <p class="type-body serv-text">{p}</p>
                    ))}
                  </div>
                )}
              </div>

              <!-- Divider -->
              <div class="serv-divider"></div>

              <!-- Bottom: deliverables -->
              <div class="serv-deliverables">
                <div class="serv-del-col">
                  <span class="type-mono-sm serv-label">Qué incluye</span>
                  <ul class="serv-includes">
                    {s.queIncluye.map((item) => (
                      <li class="type-body serv-inc-item">
                        <span class="serv-dash" aria-hidden="true">—</span>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>

                <div class="serv-del-col">
                  {s.adicionales.length > 0 && (
                    <Fragment>
                      <span class="type-mono-sm serv-label">Según el proyecto</span>
                      <ul class="serv-includes serv-includes-secondary">
                        {s.adicionales.map((item) => (
                          <li class="type-body serv-inc-item">
                            <span class="serv-dash" aria-hidden="true">—</span>
                            {item}
                          </li>
                        ))}
                      </ul>
                    </Fragment>
                  )}

                  {s.comoEmpieza.length > 0 && (
                    <div class="serv-como">
                      <span class="type-mono-sm serv-label">{s.id === 'retainer' ? 'Cómo funciona' : 'Cómo empieza'}</span>
                      {s.comoEmpieza.map((p) => (
                        <p class="type-body serv-text">{p}</p>
                      ))}
                    </div>
                  )}

                  {s.inversion && (
                    <div class="serv-como">
                      <span class="type-mono-sm serv-label">Inversión</span>
                      <p class="type-body serv-text">{s.inversion}</p>
                    </div>
                  )}
                </div>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ═══ CIERRE ═══ -->
  <section class="serv-cierre" data-mode="dark">
    <div class="serv-cierre-glow"></div>
    <div class="container">
      <div class="serv-cierre-block reveal">
        <p class="serv-cierre-text">Cada proyecto arranca con un diagnóstico.</p>
        <p class="serv-cierre-sub">
          No para venderte más — para entender exactamente qué necesitás
          y definir el alcance con precisión real.
        </p>
        <p class="serv-cierre-strong">Sin compromiso. Con <em class="serv-cierre-italic">criterio</em><span class="text-accent">.</span></p>
      </div>
      <a href="/#contacto" class="link-arrow-long serv-cierre-cta reveal" data-cursor-hover>
        <span>Agendá un diagnóstico</span>
        <span class="long-dash" aria-hidden="true">———→</span>
      </a>
    </div>
  </section>

  <Footer />
</Base>

<style>
  /* ═══════════════════════════════════════════
     HERO — compact, not full-page
     ═══════════════════════════════════════════ */
  .serv-hero {
    background-color: var(--proma-navy-900);
    color: var(--proma-cream-100);
    padding: clamp(130px, 16vh, 180px) 0 clamp(60px, 8vh, 80px);
    position: relative;
    overflow: hidden;
  }

  .serv-hero-glow {
    position: absolute;
    top: -30%;
    right: -10%;
    width: 70vw;
    height: 70vw;
    background: radial-gradient(
      ellipse at center,
      rgba(212, 82, 26, 0.05) 0%,
      rgba(212, 82, 26, 0.02) 40%,
      transparent 65%
    );
    pointer-events: none;
  }

  .serv-hero .container {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .serv-hero-title {
    font-family: var(--font-primary);
    font-size: clamp(28px, 3.5vw, 52px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    max-width: 800px;
  }

  .serv-hero-italic {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 400;
    color: var(--proma-terra-500);
    text-shadow: 0 0 30px rgba(212, 82, 26, 0.25), 0 0 60px rgba(212, 82, 26, 0.08);
  }

  .serv-hero-bottom {
    display: flex;
    gap: var(--space-6);
    max-width: 600px;
    margin-top: var(--space-4);
  }

  .serv-hero-bar {
    width: 3px;
    flex-shrink: 0;
    background: var(--proma-terra-500);
    border-radius: 2px;
  }

  .serv-hero-sub {
    opacity: 0.45;
    font-size: 14px;
    line-height: 1.7;
  }

  .serv-hero-sub strong {
    opacity: 1;
    color: var(--proma-cream-100);
  }

  /* ═══════════════════════════════════════════
     SERVICES LIST — single dark section
     ═══════════════════════════════════════════ */
  .serv-list-section {
    background-color: var(--proma-navy-900);
    color: var(--proma-cream-100);
    padding: var(--space-12) 0 clamp(80px, 10vh, 120px);
    position: relative;
    overflow: hidden;
  }

  .serv-list-glow {
    position: absolute;
    bottom: -20%;
    left: -10%;
    width: 60vw;
    height: 60vw;
    background: radial-gradient(
      ellipse at center,
      rgba(120, 80, 200, 0.03) 0%,
      rgba(60, 40, 120, 0.015) 40%,
      transparent 65%
    );
    pointer-events: none;
  }

  .serv-list-section .container {
    position: relative;
    z-index: 1;
  }

  /* ── Service item (accordion) ── */
  .serv-item {
    border-top: 1px solid rgba(242, 237, 228, 0.06);
    cursor: pointer;
  }

  .serv-item:last-child {
    border-bottom: 1px solid rgba(242, 237, 228, 0.06);
  }

  /* ── Collapsed row ── */
  .serv-row {
    display: grid;
    grid-template-columns: 48px 1fr auto 32px;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-6) 0;
    transition: padding 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .serv-ref {
    color: var(--proma-terra-500);
    font-size: 11px;
  }

  .serv-nombre {
    font-family: var(--font-primary);
    font-size: clamp(18px, 2.2vw, 28px);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .serv-tagline {
    color: rgba(242, 237, 228, 0.3);
    font-size: 11px;
    text-align: right;
    transition: opacity 0.3s ease;
  }

  .serv-toggle {
    width: 20px;
    height: 20px;
    position: relative;
    justify-self: end;
  }

  .toggle-h,
  .toggle-v {
    position: absolute;
    background: var(--proma-cream-100);
    border-radius: 1px;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
  }

  .toggle-h {
    width: 14px;
    height: 1px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .toggle-v {
    width: 1px;
    height: 14px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  /* ── Hover state ── */
  .serv-item:hover .serv-nombre {
    color: var(--proma-terra-500);
    transform: translateX(4px);
  }

  .serv-item:hover .serv-tagline {
    opacity: 0.6;
  }

  /* ── Expanded state ── */
  .serv-item.is-open .serv-row {
    padding-bottom: var(--space-4);
  }

  .serv-item.is-open .serv-nombre {
    color: var(--proma-terra-500);
  }

  .serv-item.is-open .toggle-v {
    transform: translate(-50%, -50%) rotate(90deg);
    opacity: 0;
  }

  /* ── Detail panel ── */
  .serv-detail {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .serv-item.is-open .serv-detail {
    max-height: 1200px;
  }

  .serv-detail-inner {
    padding: var(--space-4) 0 var(--space-10) 48px;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  /* ── Context columns (Para quién + Qué resuelve) ── */
  .serv-context {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-10);
  }

  .serv-context-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .serv-label {
    color: var(--proma-terra-500);
    margin-bottom: var(--space-1);
  }

  .serv-text {
    opacity: 0.45;
    font-size: 14px;
    line-height: 1.7;
  }

  /* ── Divider ── */
  .serv-divider {
    height: 1px;
    background: rgba(242, 237, 228, 0.06);
  }

  /* ── Deliverables (Qué incluye + Adicionales) ── */
  .serv-deliverables {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-10);
  }

  .serv-del-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .serv-includes {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .serv-inc-item {
    display: flex;
    gap: var(--space-3);
    font-size: 14px;
    line-height: 1.6;
    opacity: 0.55;
  }

  .serv-dash {
    color: var(--proma-terra-500);
    flex-shrink: 0;
    font-weight: 300;
  }

  .serv-includes-secondary .serv-inc-item {
    opacity: 0.35;
  }

  .serv-como {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }

  /* ═══════════════════════════════════════════
     CIERRE
     ═══════════════════════════════════════════ */
  .serv-cierre {
    background-color: var(--proma-navy-900);
    color: var(--proma-cream-100);
    padding: clamp(80px, 10vh, 140px) 0;
    position: relative;
    overflow: hidden;
  }

  .serv-cierre-glow {
    position: absolute;
    bottom: -30%;
    left: 20%;
    width: 60vw;
    height: 60vw;
    background: radial-gradient(
      ellipse at center,
      rgba(212, 82, 26, 0.05) 0%,
      rgba(212, 82, 26, 0.02) 35%,
      transparent 65%
    );
    pointer-events: none;
  }

  .serv-cierre .container {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  .serv-cierre-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    max-width: 600px;
  }

  .serv-cierre-text {
    font-family: var(--font-primary);
    font-size: clamp(24px, 3vw, 40px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
  }

  .serv-cierre-sub {
    font-size: 14px;
    line-height: 1.7;
    opacity: 0.45;
  }

  .serv-cierre-strong {
    font-family: var(--font-primary);
    font-size: clamp(24px, 3vw, 40px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
  }

  .serv-cierre-italic {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 400;
    color: var(--proma-terra-500);
    text-shadow: 0 0 30px rgba(212, 82, 26, 0.25), 0 0 60px rgba(212, 82, 26, 0.08);
  }

  .serv-cierre-cta {
    color: var(--proma-cream-100);
    font-size: 13px;
    transition: color 0.3s ease;
  }

  .serv-cierre-cta:hover {
    color: var(--proma-terra-500);
  }

  /* ═══════════════════════════════════════════
     MOBILE
     ═══════════════════════════════════════════ */
  @media (max-width: 768px) {
    .serv-row {
      grid-template-columns: 36px 1fr 24px;
      gap: var(--space-3);
    }

    .serv-tagline {
      display: none;
    }

    .serv-detail-inner {
      padding-left: 0;
    }

    .serv-context {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .serv-deliverables {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .serv-hero-bottom {
      max-width: 100%;
    }
  }
</style>

<script>
  const items = document.querySelectorAll('[data-serv-toggle]');
  items.forEach(item => {
    item.querySelector('.serv-row')?.addEventListener('click', () => {
      const wasOpen = item.classList.contains('is-open');
      items.forEach(i => i.classList.remove('is-open'));
      if (!wasOpen) item.classList.add('is-open');
    });
  });
</script>
