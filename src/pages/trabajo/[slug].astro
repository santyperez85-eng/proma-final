---
import Base from '../../layouts/Base.astro';
import { proyectos, getProyectoAnterior, getSiguienteProyecto } from '../../data/proyectos';
import type { Imagen } from '../../data/proyectos';

export function getStaticPaths() {
  return proyectos.map((p) => ({
    params: { slug: p.slug },
    props: { proyecto: p },
  }));
}

const { proyecto } = Astro.props;
const anterior = getProyectoAnterior(proyecto.slug);
const siguiente = getSiguienteProyecto(proyecto.slug);

// Separate featured from the rest
const [featured, ...resto] = proyecto.imagenes;

// Build gallery chunks: single → pair → single → pair...
type Chunk = { type: 'single'; img: Imagen } | { type: 'pair'; imgs: Imagen[] };
const chunks: Chunk[] = [];
let j = 0;
while (j < resto.length) {
  chunks.push({ type: 'single', img: resto[j] });
  j++;
  if (j < resto.length) {
    const pair = resto.slice(j, Math.min(j + 2, resto.length));
    chunks.push({ type: 'pair', imgs: pair });
    j += pair.length;
  }
}
---

<Base title={`${proyecto.titulo} — pro.ma Studio`}>
  <!-- ── BACK NAV ── -->
  <div class="proyecto-back" data-mode="dark">
    <div class="container">
      <a href="/trabajo" class="back-link" data-cursor-hover>
        <span class="back-arrow">←</span>
        <span class="type-mono-sm back-label">Volver a trabajo</span>
      </a>
    </div>
  </div>

  <!-- ── HERO HEADER ── -->
  <section class="proyecto-hero" data-mode="dark">
    <div class="glow-terra" aria-hidden="true"></div>

    <div class="container">
      <div class="proyecto-meta reveal">
        <span class="type-mono-sm proyecto-ref">{proyecto.ref}</span>
        <span class="proyecto-tipo type-label">{proyecto.tipo}</span>
      </div>

      <h1 class="proyecto-titulo reveal">{proyecto.titulo}</h1>
      <p class="proyecto-tagline type-body reveal">{proyecto.tagline}</p>

      <div class="proyecto-info reveal">
        <div class="info-block">
          <h2 class="type-label info-label">Desafío</h2>
          <p class="type-body info-text">{proyecto.desafio}</p>
        </div>

        <div class="info-block">
          <h2 class="type-label info-label">Decisiones</h2>
          <ul class="decisiones-list">
            {proyecto.decisiones.map((d) => (
              <li class="type-body decisiones-item">{d}</li>
            ))}
          </ul>
        </div>

        <div class="info-block info-resultado">
          <h2 class="type-label info-label">Resultado</h2>
          <p class="type-body info-text info-text-resultado">{proyecto.resultado}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── GALLERY ── -->
  <section class="proyecto-gallery" data-mode="dark">
    <!-- Featured image: full width, prominent -->
    <div class="gallery-featured reveal">
      <img
        src={featured.src}
        alt={featured.alt}
        class="gallery-img"
        loading="eager"
      />
    </div>

    <!-- Rest of images in alternating chunks -->
    {chunks.map((chunk) =>
      chunk.type === 'single' ? (
        <div class="gallery-single reveal">
          <div class="container">
            <img
              src={chunk.img.src}
              alt={chunk.img.alt}
              class="gallery-img"
              loading="lazy"
            />
          </div>
        </div>
      ) : (
        <div class="gallery-pair reveal">
          <div class="container">
            <div class="gallery-pair-grid">
              {chunk.imgs.map((img) => (
                <img
                  src={img.src}
                  alt={img.alt}
                  class="gallery-img"
                  loading="lazy"
                />
              ))}
            </div>
          </div>
        </div>
      )
    )}
  </section>

  <!-- ── PREV / NEXT NAVIGATION ── -->
  <nav class="proyecto-nav" data-mode="dark" aria-label="Navegación entre proyectos">
    <div class="proyecto-nav-inner">
      <div class="nav-slot nav-prev">
        {anterior ? (
          <a href={`/trabajo/${anterior.slug}`} class="nav-proyecto-link" data-cursor-hover>
            <span class="type-mono-sm nav-dir">← Anterior</span>
            <span class="type-mono-sm nav-proyecto-ref">{anterior.ref}</span>
            <span class="nav-proyecto-titulo">{anterior.titulo}</span>
            <span class="nav-proyecto-tipo type-label">{anterior.tipo}</span>
          </a>
        ) : (
          <span class="nav-slot-empty"></span>
        )}
      </div>

      <div class="nav-divider" aria-hidden="true"></div>

      <div class="nav-slot nav-next">
        {siguiente ? (
          <a href={`/trabajo/${siguiente.slug}`} class="nav-proyecto-link nav-proyecto-link-next" data-cursor-hover>
            <span class="type-mono-sm nav-dir">Siguiente →</span>
            <span class="type-mono-sm nav-proyecto-ref">{siguiente.ref}</span>
            <span class="nav-proyecto-titulo">{siguiente.titulo}</span>
            <span class="nav-proyecto-tipo type-label">{siguiente.tipo}</span>
          </a>
        ) : (
          <span class="nav-slot-empty"></span>
        )}
      </div>
    </div>
  </nav>
</Base>

<style>
  /* ── Back nav ── */
  .proyecto-back {
    background-color: var(--proma-navy-900);
    border-bottom: 1px solid rgba(242, 237, 228, 0.05);
    padding: var(--space-4) 0;
    position: sticky;
    top: 64px; /* below main nav */
    z-index: 50;
    backdrop-filter: blur(12px);
    background-color: rgba(10, 10, 15, 0.85);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--proma-cream-100);
    opacity: 0.4;
    transition: opacity 0.3s ease, color 0.3s ease;
    text-decoration: none;
  }

  .back-link:hover {
    opacity: 1;
    color: var(--proma-terra-500);
  }

  .back-arrow {
    font-family: var(--font-mono);
    font-size: 12px;
    transition: transform 0.3s ease;
  }

  .back-link:hover .back-arrow {
    transform: translateX(-4px);
  }

  .back-label {
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* ── Hero ── */
  .proyecto-hero {
    background-color: var(--proma-navy-900);
    color: var(--proma-cream-100);
    padding: clamp(64px, 8vh, 120px) 0 clamp(48px, 6vh, 96px);
    position: relative;
    overflow: hidden;
  }

  .glow-terra {
    position: absolute;
    top: -20%;
    right: -10%;
    width: 70vw;
    height: 70vw;
    background: radial-gradient(
      ellipse at center,
      rgba(212, 82, 26, 0.06) 0%,
      rgba(212, 82, 26, 0.02) 40%,
      transparent 70%
    );
    pointer-events: none;
  }

  .proyecto-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .proyecto-ref {
    color: var(--proma-terra-500);
    font-size: 11px;
    letter-spacing: 0.1em;
  }

  .proyecto-tipo {
    color: var(--proma-terra-500);
    padding: 2px var(--space-2);
    border: 1px solid rgba(212, 82, 26, 0.4);
    font-size: 9px;
    letter-spacing: 0.12em;
  }

  .proyecto-titulo {
    font-family: var(--font-primary);
    font-size: clamp(40px, 7vw, 96px);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: var(--space-4);
  }

  .proyecto-tagline {
    font-size: 15px;
    opacity: 0.4;
    max-width: 480px;
    margin-bottom: clamp(40px, 5vh, 80px);
    line-height: 1.6;
  }

  .proyecto-info {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: clamp(24px, 4vw, 64px);
    padding-top: var(--space-8);
    border-top: 1px solid rgba(242, 237, 228, 0.08);
  }

  .info-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .info-label {
    color: var(--proma-terra-500);
    font-size: 9px;
    letter-spacing: 0.12em;
    padding-bottom: var(--space-2);
    border-bottom: 1px solid rgba(242, 237, 228, 0.08);
  }

  .info-text {
    font-size: 14px;
    line-height: 1.75;
    opacity: 0.55;
  }

  .info-text-resultado {
    opacity: 0.8;
    font-weight: 500;
    font-size: 14px;
    line-height: 1.7;
  }

  .decisiones-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .decisiones-item {
    font-size: 13px;
    line-height: 1.65;
    opacity: 0.55;
    padding-left: var(--space-4);
    position: relative;
  }

  .decisiones-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 9px;
    width: 6px;
    height: 1px;
    background: var(--proma-terra-500);
  }

  /* ── Gallery ── */
  .proyecto-gallery {
    background-color: var(--proma-navy-900);
    padding-bottom: var(--space-24);
  }

  .gallery-featured {
    width: 100%;
    margin-bottom: clamp(16px, 2vw, 32px);
  }

  .gallery-featured .gallery-img {
    width: 100%;
    max-height: 90vh;
    object-fit: contain;
    display: block;
  }

  .gallery-single {
    margin-bottom: clamp(12px, 1.5vw, 24px);
  }

  .gallery-single .gallery-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .gallery-pair {
    margin-bottom: clamp(12px, 1.5vw, 24px);
  }

  .gallery-pair-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(8px, 1vw, 16px);
  }

  .gallery-pair-grid .gallery-img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Project navigation ── */
  .proyecto-nav {
    background-color: var(--proma-navy-800);
    border-top: 1px solid rgba(242, 237, 228, 0.06);
    color: var(--proma-cream-100);
  }

  .proyecto-nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    min-height: 160px;
  }

  .nav-slot {
    padding: clamp(32px, 4vh, 48px) var(--space-6);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .nav-divider {
    width: 1px;
    background: rgba(242, 237, 228, 0.06);
    align-self: stretch;
  }

  .nav-proyecto-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    text-decoration: none;
    color: var(--proma-cream-100);
    transition: all 0.3s ease;
    max-width: 320px;
  }

  .nav-next .nav-proyecto-link {
    align-items: flex-end;
    text-align: right;
    margin-left: auto;
  }

  .nav-proyecto-link:hover {
    color: var(--proma-terra-500);
  }

  .nav-dir {
    color: var(--proma-terra-500);
    font-size: 9px;
    letter-spacing: 0.12em;
    opacity: 0.6;
    margin-bottom: var(--space-1);
    transition: opacity 0.3s ease;
  }

  .nav-proyecto-link:hover .nav-dir {
    opacity: 1;
  }

  .nav-proyecto-ref {
    font-size: 10px;
    opacity: 0.3;
    letter-spacing: 0.1em;
  }

  .nav-proyecto-titulo {
    font-family: var(--font-primary);
    font-size: clamp(20px, 2.5vw, 32px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    transition: color 0.3s ease;
  }

  .nav-proyecto-tipo {
    font-size: 9px;
    letter-spacing: 0.1em;
    opacity: 0.35;
    margin-top: var(--space-1);
  }

  .nav-slot-empty {
    display: block;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .proyecto-info {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .info-resultado {
      padding-top: var(--space-6);
      border-top: 1px solid rgba(242, 237, 228, 0.06);
    }
  }

  @media (max-width: 768px) {
    .proyecto-back {
      top: 60px;
    }

    .gallery-pair-grid {
      grid-template-columns: 1fr;
    }

    .proyecto-nav-inner {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .nav-divider {
      width: 100%;
      height: 1px;
      align-self: auto;
    }

    .nav-next .nav-proyecto-link {
      align-items: flex-start;
      text-align: left;
    }
  }
</style>
