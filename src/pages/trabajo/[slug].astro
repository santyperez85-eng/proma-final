---
import Base from '../../layouts/Base.astro';
import Lightbox from '../../components/Lightbox.astro';
import { proyectos, getProyectoAnterior, getSiguienteProyecto, getTodasLasImagenes } from '../../data/proyectos';

export function getStaticPaths() {
  return proyectos.map((p) => ({
    params: { slug: p.slug },
    props: { proyecto: p },
  }));
}

const { proyecto } = Astro.props;
const anterior = getProyectoAnterior(proyecto.slug);
const siguiente = getSiguienteProyecto(proyecto.slug);
const todasImagenes = getTodasLasImagenes(proyecto);

// Build a global image index for lightbox tracking
let globalIdx = 0;
function nextIdx() { return globalIdx++; }
---

<Base title={`${proyecto.titulo} — pro.ma Studio`}>
  <!-- ── BACK NAV ── -->
  <div class="proyecto-back" data-mode="dark">
    <div class="container">
      <a href="/trabajo" class="back-link" data-cursor-hover>
        <span class="back-arrow">←</span>
        <span class="type-mono-sm back-label">Volver a trabajo</span>
      </a>
    </div>
  </div>

  <!-- ── HERO ── -->
  <section class="proyecto-hero" data-mode="dark">
    <div class="glow-terra" aria-hidden="true"></div>

    <div class="container">
      <div class="proyecto-meta reveal">
        <span class="type-mono-sm proyecto-ref">{proyecto.ref}</span>
        <span class="proyecto-tipo type-label">{proyecto.tipo}</span>
      </div>

      <h1 class="proyecto-titulo reveal">{proyecto.titulo}</h1>
      <p class="proyecto-tagline reveal">{proyecto.tagline}</p>

      <div class="proyecto-brief reveal">
        <div class="brief-block">
          <h2 class="type-label brief-label">Desafío</h2>
          <p class="brief-text">{proyecto.desafio}</p>
        </div>
        <div class="brief-block">
          <h2 class="type-label brief-label">Resultado</h2>
          <p class="brief-text brief-resultado">{proyecto.resultado}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PORTADA (full width) ── -->
  <section class="proyecto-portada" data-mode="dark">
    <div class="portada-frame">
      <img
        src={proyecto.portada.src}
        alt={proyecto.portada.alt}
        class="portada-img"
        loading="eager"
        data-lightbox
        data-full={proyecto.portada.src}
      />
    </div>
  </section>

  <!-- ── GALLERY SECTIONS ── -->
  {proyecto.secciones.map((seccion, sIdx) => (
    <section class="galeria-seccion" data-mode="dark">
      <div class="container">
        <!-- Section context -->
        <div class="seccion-context reveal">
          <div class="seccion-context-line" aria-hidden="true"></div>
          <div class="seccion-context-content">
            <span class="type-mono-sm seccion-idx">{String(sIdx + 1).padStart(2, '0')}</span>
            <h3 class="seccion-titulo">{seccion.titulo}</h3>
            <p class="seccion-texto">{seccion.texto}</p>
          </div>
        </div>

        <!-- Images grid -->
        <div class="seccion-grid">
          {seccion.imagenes.map((img) => (
            <div class={`grid-item ${img.orientacion === 'v' ? 'grid-item-v' : 'grid-item-h'}`}>
              <img
                src={img.src}
                alt={img.alt}
                class="grid-img"
                loading="lazy"
                data-lightbox
                data-full={img.src}
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- ── PREV / NEXT ── -->
  <nav class="proyecto-nav" data-mode="dark" aria-label="Navegación entre proyectos">
    <div class="proyecto-nav-inner">
      <div class="nav-slot nav-prev">
        {anterior ? (
          <a href={`/trabajo/${anterior.slug}`} class="nav-proyecto-link" data-cursor-hover>
            <span class="type-mono-sm nav-dir">← Anterior</span>
            <span class="type-mono-sm nav-proyecto-ref">{anterior.ref}</span>
            <span class="nav-proyecto-titulo">{anterior.titulo}</span>
            <span class="nav-proyecto-tipo type-label">{anterior.tipo}</span>
          </a>
        ) : (
          <span class="nav-slot-empty"></span>
        )}
      </div>

      <div class="nav-divider" aria-hidden="true"></div>

      <div class="nav-slot nav-next">
        {siguiente ? (
          <a href={`/trabajo/${siguiente.slug}`} class="nav-proyecto-link nav-link-next" data-cursor-hover>
            <span class="type-mono-sm nav-dir">Siguiente →</span>
            <span class="type-mono-sm nav-proyecto-ref">{siguiente.ref}</span>
            <span class="nav-proyecto-titulo">{siguiente.titulo}</span>
            <span class="nav-proyecto-tipo type-label">{siguiente.tipo}</span>
          </a>
        ) : (
          <span class="nav-slot-empty"></span>
        )}
      </div>
    </div>
  </nav>

  <Lightbox />
</Base>

<style>
  /* ── Back nav ── */
  .proyecto-back {
    background-color: rgba(10, 10, 15, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(242, 237, 228, 0.05);
    padding: var(--space-4) 0;
    position: sticky;
    top: 64px;
    z-index: 50;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--proma-cream-100);
    opacity: 0.5;
    transition: opacity 0.3s ease, color 0.3s ease;
  }

  .back-link:hover {
    opacity: 1;
    color: var(--proma-terra-500);
  }

  .back-arrow {
    font-family: var(--font-mono);
    font-size: 14px;
    transition: transform 0.3s ease;
  }

  .back-link:hover .back-arrow {
    transform: translateX(-4px);
  }

  .back-label {
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* ── Hero ── */
  .proyecto-hero {
    background-color: var(--proma-navy-900);
    color: var(--proma-cream-100);
    padding: clamp(48px, 6vh, 96px) 0 clamp(40px, 5vh, 80px);
    position: relative;
    overflow: hidden;
  }

  .glow-terra {
    position: absolute;
    top: -20%;
    right: -10%;
    width: 70vw;
    height: 70vw;
    background: radial-gradient(
      ellipse at center,
      rgba(212, 82, 26, 0.06) 0%,
      rgba(212, 82, 26, 0.02) 40%,
      transparent 70%
    );
    pointer-events: none;
  }

  .proyecto-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .proyecto-ref {
    color: var(--proma-terra-500);
    font-size: 11px;
    letter-spacing: 0.1em;
  }

  .proyecto-tipo {
    color: var(--proma-terra-500);
    padding: 2px var(--space-2);
    border: 1px solid rgba(212, 82, 26, 0.4);
    font-size: 9px;
    letter-spacing: 0.12em;
  }

  .proyecto-titulo {
    font-family: var(--font-primary);
    font-size: clamp(40px, 7vw, 96px);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--proma-cream-100);
    margin-bottom: var(--space-4);
  }

  .proyecto-tagline {
    font-family: var(--font-primary);
    font-size: clamp(16px, 2vw, 20px);
    color: var(--proma-cream-100);
    opacity: 0.5;
    max-width: 520px;
    margin-bottom: clamp(40px, 5vh, 72px);
    line-height: 1.5;
  }

  /* ── Brief (desafío + resultado) ── */
  .proyecto-brief {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 5vw, 64px);
    padding-top: var(--space-8);
    border-top: 1px solid rgba(242, 237, 228, 0.1);
  }

  .brief-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .brief-label {
    color: var(--proma-terra-500);
    font-size: 10px;
    letter-spacing: 0.12em;
    padding-bottom: var(--space-2);
    border-bottom: 1px solid rgba(242, 237, 228, 0.1);
  }

  .brief-text {
    font-family: var(--font-primary);
    font-size: 15px;
    line-height: 1.75;
    color: var(--proma-cream-100);
    opacity: 0.65;
  }

  .brief-resultado {
    opacity: 0.85;
    font-weight: 500;
  }

  /* ── Portada ── */
  .proyecto-portada {
    background-color: var(--proma-navy-900);
    padding: 0 0 clamp(8px, 1vw, 16px);
  }

  .portada-frame {
    max-width: 1400px;
    margin: 0 auto;
    overflow: hidden;
  }

  .portada-img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    cursor: zoom-in;
  }

  /* ── Gallery sections ── */
  .galeria-seccion {
    background-color: var(--proma-navy-900);
    color: var(--proma-cream-100);
    padding: clamp(48px, 5vh, 80px) 0;
  }

  /* Section context block */
  .seccion-context {
    display: flex;
    gap: var(--space-6);
    margin-bottom: clamp(32px, 4vh, 56px);
    align-items: flex-start;
  }

  .seccion-context-line {
    width: 3px;
    min-height: 60px;
    background: var(--proma-terra-500);
    flex-shrink: 0;
    margin-top: 4px;
    opacity: 0.6;
  }

  .seccion-context-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 560px;
  }

  .seccion-idx {
    color: var(--proma-terra-500);
    font-size: 10px;
    letter-spacing: 0.1em;
    opacity: 0.6;
  }

  .seccion-titulo {
    font-family: var(--font-primary);
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--proma-cream-100);
  }

  .seccion-texto {
    font-family: var(--font-primary);
    font-size: 14px;
    line-height: 1.7;
    color: var(--proma-cream-100);
    opacity: 0.5;
  }

  /* Images grid */
  .seccion-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-auto-flow: dense;
    gap: clamp(6px, 0.8vw, 12px);
  }

  .grid-item {
    overflow: hidden;
    background-color: var(--proma-navy-800);
  }

  .grid-item-h {
    aspect-ratio: 16 / 9;
  }

  .grid-item-v {
    aspect-ratio: 3 / 4;
    grid-row: span 2;
  }

  .grid-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    cursor: zoom-in;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .grid-item:hover .grid-img {
    transform: scale(1.03);
  }

  /* ── Prev/Next nav ── */
  .proyecto-nav {
    background-color: var(--proma-navy-800);
    border-top: 1px solid rgba(242, 237, 228, 0.06);
    color: var(--proma-cream-100);
  }

  .proyecto-nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    min-height: 160px;
  }

  .nav-slot {
    padding: clamp(32px, 4vh, 48px) var(--space-6);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .nav-divider {
    width: 1px;
    background: rgba(242, 237, 228, 0.06);
    align-self: stretch;
  }

  .nav-proyecto-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    color: var(--proma-cream-100);
    transition: color 0.3s ease;
    max-width: 320px;
  }

  .nav-next .nav-proyecto-link {
    align-items: flex-end;
    text-align: right;
    margin-left: auto;
  }

  .nav-proyecto-link:hover {
    color: var(--proma-terra-500);
  }

  .nav-dir {
    color: var(--proma-terra-500);
    font-size: 9px;
    letter-spacing: 0.12em;
    opacity: 0.6;
    margin-bottom: var(--space-1);
    transition: opacity 0.3s ease;
  }

  .nav-proyecto-link:hover .nav-dir {
    opacity: 1;
  }

  .nav-proyecto-ref {
    font-size: 10px;
    opacity: 0.3;
    letter-spacing: 0.1em;
  }

  .nav-proyecto-titulo {
    font-family: var(--font-primary);
    font-size: clamp(20px, 2.5vw, 32px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .nav-proyecto-tipo {
    font-size: 9px;
    letter-spacing: 0.1em;
    opacity: 0.35;
    margin-top: var(--space-1);
  }

  .nav-slot-empty {
    display: block;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .proyecto-brief {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  @media (max-width: 768px) {
    .proyecto-back {
      top: 60px;
    }

    .seccion-grid {
      grid-template-columns: 1fr;
    }

    .grid-item-h,
    .grid-item-v {
      aspect-ratio: 16 / 9;
    }

    .seccion-context {
      flex-direction: column;
      gap: var(--space-4);
    }

    .seccion-context-line {
      width: 40px;
      min-height: 3px;
      height: 3px;
    }

    .proyecto-nav-inner {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .nav-divider {
      width: 100%;
      height: 1px;
      align-self: auto;
    }

    .nav-next .nav-proyecto-link {
      align-items: flex-start;
      text-align: left;
    }
  }
</style>
