---
import Base from '../layouts/Base.astro';
import { proyectos } from '../data/proyectos';
---

<Base title="Trabajo — pro.ma Studio">
  <!-- ── HERO ── -->
  <section class="trabajo-hero" data-mode="dark">
    <div class="reg-mark reg-tl" aria-hidden="true"></div>
    <div class="reg-mark reg-tr" aria-hidden="true"></div>
    <div class="glow-hero" aria-hidden="true"></div>

    <div class="container trabajo-hero-inner">
      <span class="type-mono-sm text-accent reveal">REF · TRABAJOS SELECCIONADOS</span>
      <h1 class="trabajo-hero-title reveal">
        Diseño con criterio<br /><em class="trabajo-hero-italic">documentado</em><span class="text-accent">.</span>
      </h1>
      <p class="type-body trabajo-hero-sub reveal">
        Cada proyecto refleja el proceso detrás de cada decisión.<br />
        Sin fechas, sin adornos — el trabajo habla.
      </p>
    </div>
  </section>

  <!-- ── LISTING ── -->
  <section class="trabajo-listing" data-mode="dark">
    <div class="container">
      {proyectos.map((p, i) => (
        <a
          href={`/trabajo/${p.slug}`}
          class={`proyecto-row reveal ${i < proyectos.length - 1 ? 'proyecto-row-bordered' : ''}`}
          data-cursor-hover
        >
          <div class="proyecto-row-img">
            <img
              src={p.portada.src}
              alt={p.portada.alt}
              class="proyecto-cover"
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          </div>

          <div class="proyecto-row-info">
            <div class="proyecto-row-meta">
              <span class="type-mono-sm row-ref">{p.ref}</span>
              <span class="row-tipo type-label">{p.tipo}</span>
            </div>
            <h2 class="proyecto-row-titulo">{p.titulo}</h2>
            <p class="proyecto-row-tagline">{p.tagline}</p>
            <span class="proyecto-row-cta">
              <span>Ver proyecto</span>
              <span class="row-arrow" aria-hidden="true">→</span>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="trabajo-cta section" data-mode="dark">
    <div class="container trabajo-cta-inner">
      <h2 class="trabajo-cta-title reveal">
        ¿Tu próximo proyecto necesita <em class="trabajo-cta-italic">proceso</em><span class="text-accent">?</span>
      </h2>
      <a href="/#contacto" class="btn-cta reveal" data-cursor-hover>Agendá un diagnóstico</a>
    </div>
  </section>
</Base>

<style>
  /* ── Hero ── */
  .trabajo-hero {
    background-color: var(--proma-navy-900);
    color: var(--proma-cream-100);
    padding: 160px 0 80px;
    position: relative;
    overflow: hidden;
  }

  .glow-hero {
    position: absolute;
    top: -30%;
    right: -5%;
    width: 60vw;
    height: 60vw;
    background: radial-gradient(
      ellipse at center,
      rgba(212, 82, 26, 0.06) 0%,
      rgba(212, 82, 26, 0.02) 40%,
      transparent 70%
    );
    pointer-events: none;
  }

  .trabajo-hero-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .trabajo-hero-title {
    font-family: var(--font-primary);
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--proma-cream-100);
  }

  .trabajo-hero-italic {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 400;
    color: var(--proma-terra-500);
    text-shadow: 0 0 30px rgba(212, 82, 26, 0.25), 0 0 60px rgba(212, 82, 26, 0.08);
  }

  .text-accent { color: var(--proma-terra-500); }

  .trabajo-hero-sub {
    color: var(--proma-cream-100);
    opacity: 0.45;
    max-width: 440px;
    font-size: 15px;
    line-height: 1.7;
  }

  /* ── Listing ── */
  .trabajo-listing {
    background-color: var(--proma-navy-900);
    color: var(--proma-cream-100);
    padding: var(--space-6) 0 clamp(64px, 8vh, 120px);
  }

  .proyecto-row {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
    padding: clamp(48px, 6vh, 72px) 0;
    text-decoration: none;
    color: var(--proma-cream-100);
    position: relative;
  }

  .proyecto-row-bordered {
    border-bottom: 1px solid rgba(242, 237, 228, 0.08);
  }

  /* Alternate image/text position */
  .proyecto-row:nth-child(even) .proyecto-row-img {
    order: 2;
  }
  .proyecto-row:nth-child(even) .proyecto-row-info {
    order: 1;
  }

  /* ── Cover image ── */
  .proyecto-row-img {
    position: relative;
    overflow: hidden;
    background-color: var(--proma-navy-800);
  }

  .proyecto-cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .proyecto-row:hover .proyecto-cover {
    transform: scale(1.03);
  }

  /* ── Info (VISIBLE) ── */
  .proyecto-row-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .proyecto-row-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .row-ref {
    color: var(--proma-terra-500);
    font-size: 11px;
    letter-spacing: 0.1em;
  }

  .row-tipo {
    color: var(--proma-terra-500);
    font-size: 9px;
    letter-spacing: 0.12em;
    padding: 3px var(--space-2);
    border: 1px solid rgba(212, 82, 26, 0.4);
  }

  .proyecto-row-titulo {
    font-family: var(--font-primary);
    font-size: clamp(28px, 3.5vw, 48px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--proma-cream-100);
    transition: color 0.3s ease;
  }

  .proyecto-row:hover .proyecto-row-titulo {
    color: var(--proma-terra-500);
  }

  .proyecto-row-tagline {
    font-family: var(--font-primary);
    font-size: 15px;
    line-height: 1.6;
    color: var(--proma-cream-100);
    opacity: 0.55;
    max-width: 380px;
  }

  .proyecto-row-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-primary);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--proma-cream-100);
    opacity: 0.45;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    margin-top: var(--space-2);
  }

  .row-arrow {
    font-family: var(--font-mono);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .proyecto-row:hover .proyecto-row-cta {
    opacity: 1;
    color: var(--proma-terra-500);
  }

  .proyecto-row:hover .row-arrow {
    transform: translateX(6px);
  }

  /* ── CTA section ── */
  .trabajo-cta {
    background-color: var(--proma-navy-900);
    color: var(--proma-cream-100);
    border-top: 1px solid var(--proma-navy-700);
  }

  .trabajo-cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-8);
  }

  .trabajo-cta-title {
    font-family: var(--font-primary);
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--proma-cream-100);
  }

  .trabajo-cta-italic {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 400;
    color: var(--proma-terra-500);
    text-shadow: 0 0 25px rgba(212, 82, 26, 0.2), 0 0 50px rgba(212, 82, 26, 0.06);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .proyecto-row {
      grid-template-columns: 1fr;
    }

    .proyecto-row:nth-child(even) .proyecto-row-img,
    .proyecto-row:nth-child(even) .proyecto-row-info {
      order: unset;
    }
  }

  @media (max-width: 768px) {
    .trabajo-hero {
      padding: 120px 0 60px;
    }
  }
</style>
